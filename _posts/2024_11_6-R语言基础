


##while循环和repeat循环的辨析
#repeat循环
set.seed(0)
x <- seq(10,1000,1)
u <- c()#u的长度不知道，是一个空向量
i <- 1
repeat{
  u[i] <- t.test(rnorm(x[i],0.001,1),m=0,alt="greater")$p.value
  if(u[i]<0.05)break
  i <- i+1
}
i
x[i]
u

#while循环
set.seed(0)
x <- seq(10,1000,1)
u <- c()#u的长度不知道,是一个空向量
i <- 1
u[i] <- t.test(rnorm(x[i],0.001,1),m=0,alt="greater")$p.value
#要先有值才能比较
while(u[i]>=0.05){
  i <- i+1
  u[i] <- t.test(rnorm(x[i],0.001,1),m=0,alt="greater")$p.value
 
}
i
x[i]
u





